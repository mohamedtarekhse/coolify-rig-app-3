# Environment Configuration for Rigways ACM

# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PASSWORD=rigways_password

# Backend Configuration
NODE_ENV=production
PORT=3000
DB_HOST=mysql
DB_PORT=3306
DB_USER=rigways_user
DB_NAME=rigways_acm

# JWT Configuration
JWT_SECRET=change-this-secret-in-production-$(openssl rand -hex 32)
JWT_EXPIRES_SEC=86400

# CORS Configuration
CORS_ORIGIN=*

# File Upload Configuration
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
